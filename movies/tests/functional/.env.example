ELASTIC_HOST=elasticsearch
ELASTIC_PORT=9200
ELASTIC_FILM_INDEX=movies
ELASTIC_GENRE_INDEX=genres
ELASTIC_PERSON_INDEX=persons

REDIS_HOST=redis
REDIS_PORT=6379

API_URL=http://fastapi:7000
API_PREFIX=/api/v1

PROJECT_NAME=movies
CACHE_EXPIRE=1
ALLOW_HOSTS=localhost,127.0.0.1,fastapi
ORIGINS=*
PAGINATION_DEFAULT_PAGE_SIZE=50
PAGINATION_MAX_PAGE_SIZE=100

SERVICE_WAIT_MAX_ATTEMPTS=30
SERVICE_WAIT_DELAY=1.0
